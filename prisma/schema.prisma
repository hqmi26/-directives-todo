// prisma/schema.prisma

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  bio           String?
  avatarColor   String    @default("#f59e0b")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  tasks    Task[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  refresh_token_expires_in Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Task {
  id              String    @id @default(cuid())
  userId          String
  title           String
  description     String?
  completed       Boolean   @default(false)
  priority        String    @default("medium") // low | medium | high
  dueDate         DateTime?
  tags            String    @default("[]") // JSON array stored as string
  sortOrder       Int       @default(0)
  recurrence      String?   // "daily" | "weekly" | "monthly" | null
  recurrenceEnd   DateTime? // When to stop recurring
  reminderMinutes Int?      // Minutes before due date to remind
  googleEventId   String?   // Google Calendar event ID if synced
  googleCalendarId String?  // Which calendar it was added to
  syncedAt        DateTime? // Last synced with Google Calendar
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  subtasks Subtask[]
}

model Subtask {
  id        String   @id @default(cuid())
  taskId    String
  title     String
  completed Boolean  @default(false)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())

  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}
